# Python caches and build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Virtual environments and local secrets
.venv/
venv/
.env
.env.*
!.env.example

# OS and editor files
.DS_Store
.idea/
.vscode/
.ipynb_checkpoints/

# Logs
*.log

# Local Spark / Derby artifacts
metastore_db/
spark-warehouse/
derby.log

# Runtime raw/database outputs - static test data belongs in tests/fixtures/
/data/raw/*
!/data/raw/.gitkeep
/data/raw/customer_data.csv
/data/raw/customer_data_clean.csv
/data/raw/customer_data_dirty.csv
/data/raw/customer_data_api.csv
/data/raw/customer_data_db.csv
/data/database/*
!/data/database/.gitkeep
/data/database/*.db

# Runtime pipeline outputs - keep only folder placeholders
/data/bronze/*
!/data/bronze/.gitkeep

/data/silver/*
!/data/silver/.gitkeep

/data/gold/*
!/data/gold/.gitkeep

/data/audit/*
!/data/audit/.gitkeep

/output/audit/*
!/output/audit/.gitkeep

/output/dq_reports/*
!/output/dq_reports/.gitkeep

/output/quarantine/*
!/output/quarantine/.gitkeep

/output/reltio_payloads/*
!/output/reltio_payloads/.gitkeep

/output/logs/*
!/output/logs/.gitkeep

/output/observability/*
!/output/observability/.gitkeep

/output/job_control/*
!/output/job_control/.gitkeep

/output/runtime_parameters/*
!/output/runtime_parameters/.gitkeep

/output/alerts/*
!/output/alerts/.gitkeep

/output/recovery/*

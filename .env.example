# V26.0.0 - Local environment variable template
# Copy this file to .env for local experimentation only.
# Never commit .env or .env.* files.

APP_ENV=dev
PIPELINE_CONFIG_PATH=config/pipeline/local_config.json
ENVIRONMENT_CONFIG_PATH=config/environments/dev.json

CUSTOMER_SOURCE_API_CREDENTIAL=<set-locally>
CUSTOMER_DATABASE_CREDENTIAL=<set-locally>
DATABRICKS_WORKSPACE_CREDENTIAL=<set-locally>
AZURE_STORAGE_CREDENTIAL=<set-locally>

DATABRICKS_HOST=https://example.cloud.databricks.com
AZURE_KEY_VAULT_NAME=example-key-vault
POWERBI_WORKSPACE_NAME=example-workspace

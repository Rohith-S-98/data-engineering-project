# Git and local environments
.git
.gitignore
.venv
venv
.env
.env.*
!.env.example

# Python caches and build artifacts
__pycache__
*.pyc
*.pyo
.pytest_cache
.mypy_cache
.ruff_cache
.tox
.coverage
htmlcov
build
dist
*.egg-info

# Python packaging artifacts
build
dist
*.egg-info
pip-wheel-metadata

# OS and editor files
.DS_Store
.idea
.vscode
.ipynb_checkpoints

# Local Spark and Derby artifacts
metastore_db
spark-warehouse
derby.log

# Runtime raw/database outputs - fixtures remain under tests/fixtures
data/raw/*
data/raw/customer_data.csv
data/raw/customer_data_clean.csv
data/raw/customer_data_dirty.csv
data/raw/customer_data_api.csv
data/raw/customer_data_db.csv
data/database/*
data/database/*.db

# Runtime pipeline outputs
data/bronze
data/silver
data/gold
data/audit/*
!data/audit/.gitkeep
output/audit/*
!output/audit/.gitkeep
output/dq_reports/*
!output/dq_reports/.gitkeep
output/quarantine/*
!output/quarantine/.gitkeep
output/reltio_payloads/*
!output/reltio_payloads/.gitkeep
output/logs/*
!output/logs/.gitkeep
output/observability/*
!output/observability/.gitkeep
output/job_control/*
!output/job_control/.gitkeep
output/runtime_parameters/*
!output/runtime_parameters/.gitkeep
output/alerts/*
!output/alerts/.gitkeep
output/recovery/*
!output/recovery/.gitkeep

# Spark and Delta generated files
*.crc
*.snappy.parquet
_delta_log

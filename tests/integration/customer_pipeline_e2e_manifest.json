{
    "version": "v27.0.0",
    "name": "customer_pipeline_e2e_integration",
    "description": "Manifest-driven end-to-end integration checks for the customer medallion pipeline framework.",
    "default_run_date": "2026-06-23",
    "gates": [
        {
            "name": "config-validation",
            "mode": "smoke",
            "command": ["{python}", "-m", "scripts.validate_config_files"]
        },
        {
            "name": "environment-validation",
            "mode": "smoke",
            "command": ["{python}", "-m", "scripts.validate_secret_environment_config"]
        },
        {
            "name": "adf-artifact-validation",
            "mode": "full",
            "command": ["{python}", "-m", "scripts.validate_adf_artifacts"]
        },
        {
            "name": "powerbi-artifact-validation",
            "mode": "full",
            "command": ["{python}", "-m", "scripts.validate_powerbi_dashboard_artifacts"]
        },
        {
            "name": "v26-environment-tests",
            "mode": "smoke",
            "command": ["{python}", "-m", "unittest", "tests.test_v26_secret_environment_config"]
        },
        {
            "name": "dry-run-orchestrator",
            "mode": "smoke",
            "command": ["{python}", "-m", "scripts.pipeline_orchestrator", "--dry-run", "--run-date", "{run_date}"]
        },
        {
            "name": "runtime-cleanliness",
            "mode": "smoke",
            "command": ["{python}", "-m", "scripts.validate_runtime_cleanliness"]
        }
    ]
}
